# Staging environment template for Railway frontend service.
# VITE_* variables are inlined at BUILD time — must be set on the service
# before `npm run build` runs.

# Backend URL — set this to the backend service's Railway domain.
# Example: https://habit-tracker-backend-staging.up.railway.app
VITE_API_URL=

# Provided by Railway automatically — `npm run start` reads ${PORT}.
# PORT=3000
