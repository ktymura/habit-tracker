# Staging environment template for Railway backend service.
# Copy and configure via `railway variables` or the dashboard.

# Provided automatically by Railway when Postgres plugin is linked.
# Railway gives postgresql://..., the backend normalizes it to postgresql+psycopg://...
DATABASE_URL=

# Auth secrets — generate fresh values for staging (e.g. `openssl rand -hex 32`).
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

APP_NAME=Habit Tracker API (staging)
APP_VERSION=0.1.0
DEBUG=False

# Comma-separated list of allowed origins for the frontend deployment.
# Example: https://habit-tracker-frontend-staging.up.railway.app
CORS_ALLOWED_ORIGINS=

# Provided by Railway automatically — the entry script reads ${PORT}.
# PORT=8000
